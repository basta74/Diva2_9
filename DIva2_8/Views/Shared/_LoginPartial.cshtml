@using Diva2.Core.Main.Trans
@using Diva2Web.Models.Admin
@model AdminPageModel


    @if (Model.User.Id.HasValue)
{

     
    int kr = 0;


    Model.User.Zbytek.Kredity.TryGetValue(Model.Pobocka.PokladnaId, out kr);

                            

      
    <div class="dropdown">
        <a href="#" class="dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="true"
               style="text-decoration: none; font-size: large">
            @Model.User.CeleJmeno
        </a>
        <div class="dropdown-menu">
            <a class="dropdown-item" href="moje-data">Moje data</a>
            <a class="dropdown-item" href="/Account/Detail">Detail</a>
            <hr class="dropdown-divider">
            <a class="dropdown-item" href="/Account/Logout">Odhlásit</a>

        </div>
              
    </div>

    <span>
        kredit neomezený: @kr
    </span>
    @if (Model.GetIniPobBool("kreditCasovy"))
    {
        long unixTime = ((DateTimeOffset)DateTime.Now).ToUnixTimeSeconds();


        var krCas = Model.User.Zbytek.KredityCas.Where(d => d.PokladnaId == Model.Pobocka.PokladnaId && d.PlatnostDoUnix > unixTime);

        if (krCas != null)
        {
            int co = @krCas.Sum(d => d.Kredit);
            if (co > 0)
            {
                <span> časový @co </span>
            }
        }
    }

        
                        




  
}
else
{
    <a class="btn btn-outline-primary" href="/Account/Login">Log in</a>
    <a class="btn btn-outline-primary" href="/Account/Register">Registrace</a>
}
