@model LoginModel

@{
    ViewBag.Title = "Login";
}

@using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <!--Grid row-->
    <div class="row d-flex justify-content-center">
        <!--Grid column-->
        <div class="col-md-6">
            <div class="card">
                <h5 class="card-title">Přihlášení</h5>
                <div class="card-body">
                    <div class="form-horizontal">
                        @Html.ValidationSummary(true)

                        <div class="form-group">
                            @Html.LabelFor(model => model.UserName, new { @class = "control-label col-lg-2" })
                            <div class="col-lg-10">
                                @Html.TextBoxFor(model => model.UserName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.UserName)
                            </div>
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Password, new { @class = "control-label col-lg-2" })
                            <div class="col-lg-10">
                                @Html.PasswordFor(model => model.Password, new { @class = "form-control", @style = "max-width:600px;" })
                                @Html.ValidationMessageFor(model => model.Password)
                            </div>
                        </div>
                        <div class="form-group form-check">
                            <div class="col-lg-10">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-md-offset-2 col-md-10">
                                <input type="submit" value="Přihlásit" class="btn btn-primary" />
                            </div>
                        </div>
                        <div class="form-group">
                            <p>
                                <a id="forgot-password" asp-action="ForgotPassword" asp-controller="account">zapomenuté heslo?</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--Grid column-->
    </div>
    <!--Grid row-->
}