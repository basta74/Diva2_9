@using Diva2Web.Models.Admin
@using Diva2.Core.Main.Lessons
@model AdminPageModel
@{
    ViewData["Title"] = "Home Page";

}


@section leftMenu{
    <partial name="MenuLeftPublic" model="Model" />
}


@{

    if (Model.Lektori != null && Model.Lektori.Count > 0)
    {
        <h4>Lektoři</h4>
        <table class="table table-bordered">
            <tbody>
                @foreach (var pl in Model.Lektori)
                {
                    <tr>
                        <td rowspan="2" style="width: 25%"></td>
                        <td style="width: 20%"><b class="motiv-hlavni">@pl.Jmeno</b></td>
                        <td><b class="motiv-kontra">@pl.Nick</b></td>
                        <td>@pl.Email</td>
                        <td>@pl.Tel</td>
                    </tr>
                    <tr>
                        <td></td>
                        <td colspan="3">@pl.Popis</td>
                    </tr>
                    <tr>
                        <td colspan="5" style="border-left-color: none; border-right-color: none; height: 20px"></td>
                    </tr>

                }
            </tbody>
        </table>
    }
}


