@model LoginWith2faModel
@{
    ViewData["Title"] = "Dvojúrovňové ověření";
Layout = "~/Views/Shared/_LayoutAccount.cshtml";
}

<h1>@ViewData["Title"]</h1>
<hr />
<p>Vaše přihlášení je chráněno ověřovací aplikací. Zadejte prosím ověřovací kód.</p>
<div class="row">
    <div class="col-md-4">
        <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
            <input asp-for="RememberMe" type="hidden" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TwoFactorCode"></label>
                <input asp-for="TwoFactorCode" class="form-control" autocomplete="off" />
                <span asp-validation-for="TwoFactorCode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <div class="checkbox">
                    <label asp-for="RememberMachine">
                        <input asp-for="RememberMachine" />
                        @Html.DisplayNameFor(m => m.RememberMachine)
                    </label>
                </div>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Přihlásit se</button>
            </div>
        </form>
    </div>
</div>
<p>
   Nemáte přístup k ověřovacímu zařízení? Můžete se 
    <a id="recovery-code-login" asp-action="LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">přihlásit obnovovacím kódem</a>.
</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
