@using Diva2Web.Models.Users
@model UserConfirmEmailModel


@{
    ViewData["Title"] = "Aktivace";
    Layout = "~/Views/Shared/_LayoutAccount.cshtml";
}




<div class="card" style="max-width: 600px; min-width: 400px">
    <div class="card-body">
        <h5 class="card-title">Aktivace</h5>
        @Html.ValidationSummary(true)
        @if (Model.JsonStatus.Status == false)
        {

        @foreach (var msg in Model.JsonStatus.Messages)
            {
        <div class="alert alert-@msg.Type.ToString()" role="alert">
            @msg.Text;
        </div>
            }

        <div class="row">
            <div class="col-6"></div>
            <div class="col-6"><a href="/Home/Index" class="btn btn-primary">Zpět na rozvrh</a></div>
        </div>
        }
        else
        {
        <div class="alert alert-success" role="alert">
            Aktivace proběhla úspěšně :)
        </div>

        <div class="row">
            <div class="col-6"><a href="/Account/Login" class="btn btn-success">Přihlásit</a></div>
            <div class="col-6"><a href="/Home/Index" class="btn btn-secondary">Zpět na úvod</a></div>
        </div>
        }




    </div>
</div>



