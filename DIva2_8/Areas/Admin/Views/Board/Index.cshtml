        var zakaznici = new Array();

        function GetZakazniky(str) {

            $("#zakazniciSeznamAjax").html("");
            $("#js-zak-progress .progress-bar").width(100);

            if (str.length === 0) {
                document.getElementById("zakazniciSeznamAjax").innerHTML = "";
                return;
                }

                var meth = "abc";
            if (typeof zakaznici[str] === 'undefined') {
                $("#js-zak-progress .progress-bar").show(100);
                $("#js-zak-progress .progress-bar").animate({width: "100%"}, 400);
                $.ajax({
                    type: 'GET',
                    url: '/Admin/Customer/GetAjaxData',
                        data: { method: meth, value: str },
                    cache: false
                }).done(function (data) {


                    console.log(data);


                    zakaznici[str] = data;


                    var table = WriteZakTable(data, meth);

                    $("#zakazniciSeznamAjax").html(table);

                    $("#js-zak-progress .progress-bar").animate({ width: "100%" }, 50, function () {
                        $("#js-zak-progress .progress-bar").hide(100, function () {
                            $("#js-zak-progress .progress-bar").animate({width: "0%"}, 10);
                        });
                    });
                });
            } else {

                var table2 = WriteZakTable(zakaznici[str], meth);
                $("#zakazniciSeznamAjax").html(table2);
                $("#js-zak-progress .progress-bar").animate({width: "100%"}, 50, function () {
                    $("#js-zak-progress .progress-bar").hide(100, function () {
                        $("#js-zak-progress .progress-bar").animate({width: "0%"}, 10);
                    });
                });
            }
        }

        function WriteZakTable(data, meth) {
            var delkaPism = 1;

            console.log(meth);

            if (((meth === 'abc')) === true) {
                delkaPism = 2;
            }

            var pisPism = meth;
            var table = "";
            var t = "";
            var count = 0;
            var prvPismOld = "";
            if (data.ItemsCount === 0) {
                table = 'Nalezeno 0 záznamů.'

            } else {
                count = data.items.length;
                if (!(meth === 'email' || meth === 'cat-email')) {
                    if (meth.startsWith('top')) {
                        t += drawTR("Id", "Návštěvy");
                    } else {
                        t += drawTRdefault();
                    }
                }
                var oddEm = '';
                for (var index1 = 0; index1 < count; index1++) {

                    var row1 = data.items[index1];
                    if (meth != "000") {
                        if (pisPism) {
                            var prvPism = row1.nameClear.substring(0, delkaPism)
                            if (prvPism !== prvPismOld) {
                                t += '<tr><td  class="nadpis"><b>' + prvPism + '</b></td><td class="nadpis"></td><td class="nadpis" style="width: 70px"></td></tr>';
                            }
                        }
                    }
                    t += draw(row1);

                    prvPismOld = prvPism;

                }
                table = t;
            }
            return table;
        }


        function draw(o) {
            var ro = "";

            console.log(o);

            ro += '<tr class="jsFormModal" data-id="' + o.id + '"><td class="jmeno"><b style="color: #0B61A4; padding-left: 15px; ">' + o.name + '</b><br>&nbsp;<span style="color: gray; font-size:12px">' + o.id + ' > ' + o.street + ' ' + o.post + '</span></a></td>';
            ro += '<td><div data-id="' + o.id + '" class="btn btn-outline-secondary btn-sm js-add">Přidat</div></td>';

            if (o.kreditCas != null) {
                ro += '<td class="kredit-' + o.color + '">' + o.kreditCasStr + '</td>'
            }
            else if (o.kredit != null) {
                ro += '<td class="kredit-' + o.color + '">' + o.kredit + '</td>'
            }
            else {
                ro += '<td></td>'
            }

            ro += '</tr>';
            return ro;
        }

