    function writeObjTable(data) {

        var table = '<table style="width: 100%">';
        var t = "";
        var count = 0;
        if (data.ItemsCount === 0) {
            table = 'Nalezeno 0 záznamů.'

        } else {
            count = data.items.length;

            for (var index1 = 0; index1 < count; index1++) {

                var row1 = data.items[index1];

                t += '<tr><td><a href="/Admin/Board/Index/' + row1.id + '" class="badge badge-info" >lekce</a> </td><td>' + row1.d + '</td><td>' + row1.h + '</td></tr>';

            }
            table = t + '</table>';
        }
        return table;
    }

