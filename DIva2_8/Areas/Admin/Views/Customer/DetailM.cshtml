@using Diva2Web.Models.Zakaznici
@using Diva2Web.Models.Admin
@using Diva2.Core.Main.Trans
@using System.Text.Json;
@using Diva2.Core.Extensions;

@model ZakaznikDetailModel

@{
    Random rnd = new Random();
    int contrCislo = rnd.Next(10000, 99999);

    ZakaznikModel zakaznik = Model.Zakaznik;

    int Y = zakaznik.TransakceYears.LastOrDefault();

    Random ra = new Random();
    int kontCislo = ra.Next(1000, 9999);


    int kontCisloPass = ra.Next(10000, 99999);


    int kredity = zakaznik.Zbytek.KredityItem(Model.Pobocka.PokladnaId);
    var krc = zakaznik.Zbytek.KredityTimeItem(Model.Pobocka.PokladnaId, DateTime.Now);
    int krcKredit = 0;
    string krcZbyva = "";
    if (krc != null)
    {
        krcKredit = krc.Kredit;
        krcZbyva = krc.ZbyvaDni;
    }


}

<div class="modal fade" id="mustr-edit" tabindex="-1" role="dialog" aria-labelledby="addContactLabel" aria-hidden="true" data-id="@Model.Id">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <table class="modal-title" style="width: 95%">
                    <tr>
                        <td><h5 style="color: #4393E1" id="addContactLabel">@zakaznik.Name</h5></td>
                        <td><h5 style="color: #4393E1">id: <span style="color: orange">@zakaznik.Id</span></h5>   </td>
                        <td><h5 style="color: #4393E1">k: <span style="color: orange" id="jsKredity">@kredity</span> </h5> </td>

                        @{

                            string kcstr = "";
                            if (krcKredit > 0)
                            {
                                if(krc.PlatnostUnixBreak == null)
                                {
                                    kcstr = $"{krcKredit} / {krcZbyva}";
                                }
                                else
                                {
                                    kcstr = $"{krcKredit} / stop";
                                }

                            }
                        }
                        <td><h5 style="color: #4393E1">kč: <span style="color: orange" id="jsKredityCasove">@kcstr</span></h5></td>

                    </tr>
                </table>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="modal-body" style="padding: 2px">

                <div class="row" id="js-css-view">
                    <!-- levá strana výpisy -->
                    <div class="col-7">

                        <div class="card">
                            <div class="card-header">
                                Vkládání kreditu
                            </div>
                            <div class="card-body" style="padding: 2px">
                                <div class="btn-group btn-group-sm" role="group" aria-label="..." style="width: 100%">
                                    <button class="btn btn-outline-primary btn-xs js-show-m" data-t="1">Kredit</button>
                                    <button class="btn btn-outline-success btn-xs js-show-m" data-t="2">Kredit slev.</button>
                                    @if (Model.IniDict["kreditCasovy"])
                                    {
                                        <button class="btn btn-outline-secondary btn-xs js-show-m" data-t="3">Kredit časový</button>
                                        <button class="btn btn-outline-success btn-xs js-show-m" data-t="4">Kredit časový slev.</button>
                                    }
                                </div>

                                <div>
                                    <form id="jsAddMoneyForm" class="form-inline" style="display: none; background-color: aliceblue; margin: 10px 2px">
                                        <input type="hidden" name="UserId" value="@zakaznik.Id">
                                        <input type="hidden" name="TypPlatbyId" id="typPlatbyId" value="">
                                        <input type="hidden" name="DoPokladny" id="DoPokladny" value="1">
                                        <div id="drop-money" style="width: 100%">
                                        </div>
                                        <table style="margin: 10px">
                                            @if (Model.IniDict["kredit_casovy_zobraz_od"])
                                            {
                                                <tr>
                                                    <td>Platnost od</td>
                                                    <td>
                                                        <input type="date" class="form-control" id="dateFrom" name="dateFrom" value="dd. MM. yyyy" />
                                                    </td>
                                                </tr>
                                            }

                                            @if (Model.IniDict["kredit_casovy_zobraz_do"])
                                            {
                                                <tr>
                                                    <td>Platnost do</td>
                                                    <td>
                                                        <input type="date" class="form-control" id="dateTo" name="dateTo" value="dd. MM. yyyy" />
                                                    </td>
                                                </tr>
                                            }

                                            <tr>
                                                <td> Kont č: @kontCislo</td>
                                                <td>
                                                    <div>
                                                        <label for="inputPassword2" class="sr-only">Kontrolní číslo</label>
                                                        <input type="text" class="form-control" name="KontCislo1" placeholder="napište: @kontCislo">
                                                    </div>
                                                </td>
                                                <td colspan="2">
                                                    <input type="hidden" value="@kontCislo" name="KontCislo2" />
                                                    <button type="submit" id="btnAddMoneySave" class="btn btn-sm btn-success">Přidat platbu</button>
                                                </td>
                                            </tr>
                                        </table>
                                    </form>
                                </div>

                                <div id="messagesDetailCustomer" style="margin-top: 15px"></div>
                            </div>
                        </div>
                        @{
                            int kr = 0;
                            zakaznik.Zbytek.Kredity.TryGetValue(Model.Pobocka.PokladnaId, out kr);

                            string visibleCardTransakce = "display: none";
                            string visibleCardTransakcePrijem = "display: none";
                            if (Model.OpenTab == "jsCardTransakcePrijem")
                            {
                                visibleCardTransakcePrijem = "";
                            }
                            if (Model.OpenTab == "jsCardTransakce")
                            {
                                visibleCardTransakce = "";
                            }

                        }

                        <!-- Kredity -->
                        <div class="card" style="margin-top: 15px">
                            <div class="card-header">
                                <div class="row">
                                    <div class="col-4">Zbytek kreditů</div>
                                    <div class="col-8"><b style="color: #4393E1" id="jsKredity2">Neomezené kredity: @kr</b></div>
                                </div>
                            </div>
                            <div class="card-body" style="padding: 10px 7px; background-color: lightskyblue">

                                @if (Model.IniDict["kreditCasovy"])
                                {
                                    long unixTime = ((DateTimeOffset)DateTime.Now).ToUnixTimeSeconds();


                                    var krCas = zakaznik.Zbytek.KredityCas.Where(d => d.PokladnaId == Model.Pobocka.PokladnaId && d.PlatnostDoUnix > unixTime);
                                    bool spustit = false;
                                    if (krCas != null)
                                    {
                                        <table id="js-table-kredity-casove" class="table-bordered tableTrans" style="background-color: white">
                                            <tr class="nadpis">
                                                <td>Typ</td>
                                                <td>Kredit</td>
                                                <td>Plat. od</td>
                                                <td>Plat. do</td>
                                                <td>Zbývá dní</td>
                                            </tr>

                                            @foreach (UserZbytekKreditCas zb in krCas)
                                            {
                                                var dateCreated = DateTimeExtensions.FromUnix(@zb.KreditUnixTime);
                                                string prodlouzeno = zb.Prodlouzeno ? "*" : "";
                                                <tr data-id="@zb.Id" data-dou="@zb.PlatnostDoUnix">
                                                    <td>kredit časový</td>
                                                    <td><b>@zb.Kredit</b></td>
                                                    @if (zb.Aktivni)
                                                    {
                                                        if (zb.PlatnostUnixBreak != null && zb.PlatnostUnixBreak > 0)
                                                        {
                                                            spustit = true;
                                                            <td>Zastaveno</td>
                                                            <td><button type="button" class="btn btn-sm btn-danger btn6 js-edit-pl-show-spust" data-count="8888">Spustit</button></td>
                                                        }
                                                        else
                                                        {
                                                            <td>@zb.PlatnostOd.ToString("dd.MM.yyyy")</td>
                                                            <td><b>@zb.PlatnostDo.ToString("dd.MM.yyyy")  @prodlouzeno</b></td>
                                                        }

                                                        if(!spustit){
                                                            <td class="js-edit-pl-show" data-enable="1" title="Prodloužit platnost">@DateTimeExtensions.ZbyvaDni(zb.PlatnostDoUnix) @prodlouzeno</td>
                                                        }
                                                        else
                                                        {
                                                            <td></td>
                                                        }

                                                    }
                                                    else
                                                    {
                                                        <td colspan="2">Neaktivováno</td>
                                                        <td style="cursor: pointer;">
                                                            @if (DateTime.Now.Date == dateCreated.Date)
                                                            {
                                                                <div class="badge badge-info js-del-credit">Vrátit</div>
                                                            }
                                                        </td>
                                                    }

                                                </tr>
                                            }
                                        </table>
                                        <div id="js-edit-pl-div" data-id="0" data-count="0" data-dou="0" style="display: none; background-color: white">

                                            <table style="width: 100%">

                                                @if (!spustit)
                                                {
                                                    <tr>
                                                        <td rowspan="2" style="padding: 3px">Prodloužit <br /> platnost o</td>
                                                        <td id="js-edit-pld-7"></td>
                                                        <td id="js-edit-pld-14"></td>
                                                        <td id="js-edit-pld-30"></td>
                                                        <td id="js-edit-pld-61"></td>
                                                        <td id="js-edit-pld-91"></td>
                                                        <td>Stop</td>
                                                        <td id="js-edit-pld-999"></td>
                                                    </tr>
                                                    <tr>
                                                        <td><button type="button" class="btn btn-sm btn-primary btn6 js-edit-pl" data-count="7">+1 týd</button></td>
                                                        <td><button type="button" class="btn btn-sm btn-primary btn6 js-edit-pl" data-count="14">+2 týd</button></td>
                                                        <td><button type="button" class="btn btn-sm btn-primary btn6 js-edit-pl" data-count="30">+ 1 měs</button></td>
                                                        <td><button type="button" class="btn btn-sm btn-primary btn6 js-edit-pl" data-count="61">+ 2 měs</button></td>
                                                        <td><button type="button" class="btn btn-sm btn-primary btn6 js-edit-pl" data-count="91">+ 3 měs</button></td>
                                                        <td><button type="button" class="btn btn-sm btn-danger btn6 js-edit-pl" data-count="7777">stop</button></td>
                                                        <td><button type="button" class="btn btn-sm btn-secondary btn6 js-edit-pl" data-count="999">neom.</button></td>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td colspan="6" id="js-edit-pl-form" style="text-align: center; display: none;">
                                                        <div style="padding: 3px" id="js-edit-pl-text-0">Prodloužit platnost do : <b><span id="js-edit-pl-text"></span></b></div>
                                                        <button type="button" class="btn btn-sm btn-success btn6" id="js-edit-pl-send">Potvrdit</button>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                        <div id="js-del-credit-div" data-id="0" data-count="0" data-dou="0" style="display: none; background-color: white">
                                            <form id="jsRemoveMoneyForm" class="form-inline" style="display: none; background-color: aliceblue; margin: 10px 2px">
                                                <input type="hidden" name="UserId" value="@zakaznik.Id">
                                                <input type="hidden" name="PlatbaId" id="js-del-credit-id" value="">
                                                <table>
                                                    <tr>
                                                        <td> Kont č: @kontCislo</td>
                                                        <td>
                                                            <div>
                                                                <label for="inputPassword2" class="sr-only">Kontrolní číslo</label>
                                                                <input type="text" class="form-control" name="KontCislo1" placeholder="napište: @kontCislo">
                                                            </div>
                                                        </td>
                                                        <td colspan="2">
                                                            <input type="hidden" value="@kontCislo" name="KontCislo2" />
                                                            <input type="button" value="Smazat" class="btn btn-sm btn-warning js-delete-next">
                                                            <button type="submit" id="js-del-credit-force" class="btn btn-sm btn-danger" style="display: none;">Opravdu smazat</button>
                                                        </td>
                                                    </tr>
                                                </table>

                                            </form>


                                        </div>
                                        <div id="messagesDetailCustomerRemoveCredit" style=""></div>
                                    }
                                }

                            </div>
                        </div>

                        <div class="btn-group" role="group" aria-label="Basic example" style="width: 99%; margin: 20px 0 0px">
                            <button type="button" class="btn btn-sm btn-outline-secondary jsPohNaUctu" onclick="showTransaction()">Pohyby na účtu</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary jsObjLek" onclick="showObjednavky()">Objednané lekce</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary jsPrijmDokl" onclick="showTransactionPrijem()">Příjmové doklady</button>
                        </div>

                        <div class="card" id="jsCardTransakce" style="margin-top: 15px; @visibleCardTransakce">
                            <div class="card-header">
                                <b>Pohyby na účtě</b>
                            </div>
                            <div class="card-body" id="mainCardBody" style="padding: 10px 7px;">
                                <nav aria-label="Page navigation example">
                                    @{
                                        int o1 = 0;
                                    }
                                    <ul class="pagination">
                                        @foreach (int y in zakaznik.TransakceYears.OrderByDescending(d => d))
                                        {
                                            o1++;
                                            if (o1 < 7)
                                            {
                                                <li class="page-item" style="cursor: pointer;"><div class="page-link  jsSetYearTrans" data-id="@y">@y</div></li>
                                            }
                                        }
                                    </ul>
                                </nav>
                                <table class="table-bordered tableTrans" style="width: 99%">
                                    <tr class="nadpis">
                                        <td colspan="3">datum / provedl</td>
                                        <td>Typ kreditu</td>
                                        <td>+/-</td>
                                        <td>kred.</td>
                                        <td>Kč</td>
                                        <td>Zbytek</td>
                                        <td>Doklad</td>
                                    </tr>
                                    <tbody id="jsTableTransBody">
                                        @{
                                            var data = zakaznik.Transakce;
                                        }
                                        @foreach (UserTransakce tran in data.Where(d => d.Datum.Year == Y))
                                        {
                                            string krt = tran.Typ == "k" ? "standardní" : "časový";
                                            string kc = tran.Castka > 0 ? $"{tran.Castka} kč" : "";

                                            <tr>
                                                <td class="dt">@tran.Datum.ToString("dd.MM.yyyy")</td>
                                                <td class="tm">@tran.Datum.ToString("HH:mm")</td>
                                                <td class="stt">@tran.ProvedlId</td>
                                                <td class="krt">@krt</td>
                                                <td class="stt">@tran.Status</td>
                                                <td class="kr">@tran.Kredit</td>
                                                <td class="kc">@kc</td>
                                                <td class="zb">@tran.Zbytek</td>
                                                <td style="cursor: pointer;">
                                                    @if (tran.Doklad > 0)
                                                    {
                                                        <div class="badge badge-primary" onclick="$('#pokladniDoklad').printpok(@tran.Id);"> Tisk </div>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>

                                </table>
                            </div>
                        </div>

                        <div class="card" id="jsCardObjednavky" style="margin-top: 15px; @visibleCardTransakce">
                            <div class="card-header">
                                <b>Objednané hodiny</b>
                            </div>
                            <div class="card-body" id="jsCardObjednavkyBody" style="padding: 10px 7px;">
                            </div>
                        </div>

                        <div class="card" id="jsCardTransakcePrijem" style="margin-top: 15px; @visibleCardTransakcePrijem">
                            <div class="card-header">
                                <b>Příjmové doklady</b>
                            </div>
                            <div class="card-body" id="mainCardBody" style="padding: 10px 7px;">
                                <nav aria-label="Page navigation example">
                                    @{
                                        int o2 = 0;
                                    }
                                    <ul class="pagination">

                                        @foreach (int y in zakaznik.TransakceYears.OrderByDescending(d => d))
                                        {
                                            o2++;
                                            if (o2 < 7)
                                            {
                                                <li class="page-item" style="cursor: pointer;"><div class="page-link  jsSetYearTransPrijem" data-id="@y">@y</div></li>
                                            }
                                        }
                                    </ul>
                                </nav>
                                <table class="table-bordered tableTrans">
                                    <tr class="nadpis">
                                        <td colspan="3">datum / provedl</td>
                                        <td>Typ kreditu</td>
                                        <td>+/-</td>
                                        <td>kred.</td>
                                        <td>Kč</td>
                                        <td>Zbytek</td>
                                        <td>Doklad</td>
                                    </tr>
                                    <tbody id="jsTableTransPrijemBody">
                                        @{
                                            var dataPrijm = zakaznik.Transakce.Where(d => d.Status == "+" || d.Doklad > 0);
                                        }
                                        @foreach (UserTransakce tran in dataPrijm.Where(d => d.Datum.Year == Y))
                                        {
                                            string krt = tran.Typ == "k" ? "standardní" : "časový";
                                            string kc = tran.Castka > 0 ? $"{tran.Castka} kč" : "";

                                            <tr>
                                                <td class="dt">@tran.Datum.ToString("dd.MM.yyyy")</td>
                                                <td class="tm">@tran.Datum.ToString("HH:mm")</td>
                                                <td class="stt">@tran.ProvedlId</td>
                                                <td class="krt">@krt</td>
                                                <td class="stt">@tran.Status</td>
                                                <td class="kr">@tran.Kredit</td>
                                                <td class="kc">@kc</td>
                                                <td class="zb">@tran.Zbytek</td>
                                                <td style="cursor: pointer;">
                                                    @if (tran.Doklad > 0)
                                                    {
                                                        <div class="badge badge-primary" onclick="$('#pokladniDoklad').printpok(@tran.Id);"> Tisk </div>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>

                                </table>
                            </div>
                        </div>

                    </div>
                    <!-- pravá strana zákazník -->
                    <div class="col-5">
                        <div class="card">
                            <div class="card-header">

                                <table style="width: 100%">
                                    <tr>
                                        <td>Detail</td>
                                        <td style="text-align: right;"><a href="/Admin/Help/Zakaznik" class="badge badge-info">Nápověda</a></td>
                                        <td style="text-align: right;"><button class="btn btn-sm btn-outline-primary btn6" onclick="switchEdit()">Edit</button></td>
                                    </tr>
                                </table>

                            </div>
                            <div class="card-body" style="padding: 10px 7px;">

                                <table style="border-collapse: collapse; width: 100%" id="zakaznik-detail">
                                    <tbody>
                                        <tr>
                                            <td class="nadpis">ID :</td>
                                            <td>@zakaznik.Id</td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Int. číslo :</td>
                                            <td>@zakaznik.Number</td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Jméno :</td>
                                            <td><b>@zakaznik.Name</b></td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Email :</td>
                                            <td>@zakaznik.Email</td>
                                        </tr>

                                        <tr>
                                            <td class="nadpis">Telefon :</td>
                                            <td>@zakaznik.Phone</td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Adresa :</td>
                                            <td>@zakaznik.Street</td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis"></td>
                                            <td>@zakaznik.Zip  @zakaznik.Post</td>
                                        </tr>

                                        <tr>
                                            <td colspan="2" align="center">
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Aktivní</td>
                                            <td>

                                                @if (zakaznik.Aktivni)
                                                {
                                                    <span style="color: green; float: left;"><b> Aktivní</b></span>
                                                }
                                                else
                                                {
                                                    <div class="custom-control custom-switch js-switch" style="min-height: 0.5rem; float: left;">
                                                        <input type="checkbox" class="custom-control-input" data-che="" data-name="zakAkt">
                                                        <label class="custom-control-label" for="zakAkt"></label>
                                                    </div>
                                                    <span style="color: red; float: left;"> Neaktivní</span>
                                                }
                                            </td>
                                        </tr>

                                        <tr>
                                            <td colspan="2" align="center">
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Gdpr :</td>
                                            <td>
                                                @if (zakaznik.GdprBase.HasValue)
                                                {
                                                    @if (zakaznik.GdprDt.HasValue)
                                                    {
                                                        @zakaznik.GdprDt.Value.ToString("dd.MM.yyyy HH:mm")
                                                        ;
                                                    }
                                                    else
                                                    {
                                                        <div style="color: Red">
                                                            Je potvrzen ale není datum
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <div style="color: Red">
                                                        Není potvrzen
                                                    </div>
                                                }
                                            </td>
                                        </tr>

                                        <tr>
                                            <td class="nadpis">Zasílání novinek :</td>
                                            <td>
                                                @if (zakaznik.GdprNews.HasValue)
                                                {
                                                    if (zakaznik.GdprNewsDT.HasValue)
                                                    {
                                                        if (zakaznik.GdprNews.Value)
                                                        {
                                                            <div style="color: forestgreen">
                                                                @zakaznik.GdprNewsDT.Value.ToString("dd.MM.yyyy HH:mm") - Souhlasil
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div style="color: orangered">
                                                                @zakaznik.GdprNewsDT.Value.ToString("dd.MM.yyyy HH:mm") - Zakázal
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div style="color: Red">
                                                            Je potvrzen ale není datum
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <div>Nevyjádřil se</div>
                                                }

                                            </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2" align="center">
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="nadpis">Může mít slevu</td>
                                            <td>
                                                @{
                                                    string che3 = @zakaznik.MayCheaper ? "checked" : "";
                                                }

                                                <div class="custom-control custom-switch js-switch" style="min-height: 0.5rem; float: left;">
                                                    <input type="checkbox" class="custom-control-input" data-che="@che3" data-name="zakMayCheaper" @che3>
                                                    <label class="custom-control-label" for="zakMayCheaper"></label>
                                                </div>

                                                @if (zakaznik.MayCheaper)
                                                {
                                                    <span style="color: green">&nbsp;<b>Ano</b></span>
                                                }
                                                else
                                                {
                                                    <span style="color: red">&nbsp;Ne</span>
                                                }
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>

                                <!--  Skupina zákazníků -->
                                <div class="card" style="margin-top: 10px">
                                    <div class="card-header">
                                        <table style="width: 100%">
                                            <tr>
                                                <td>Skupina zákazníků</td>
