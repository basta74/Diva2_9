<script>

    $(document).ready(function () {

        $.fn.extend({
            printpok: function (tid) {

                var saa = this;

                $.ajax({
                    type: 'POST',
                    url: '/Admin/Customer/Receipt',
                    data: { id: tid },
                    cache: false
                }).done(function (data) {
                    $("#pokladniDoklad").html(data);

                    var frameName = 'printIframe';
                    var doc = window.frames[frameName];
                    if (!doc) {
                        $('<iframe>').hide().attr('name', frameName).appendTo(document.body);
                        doc = window.frames[frameName];
                    }
                    doc.document.body.innerHTML = saa.html();
                    doc.window.print();
                    return saa;

                });
            }
        });
    });


    var zakId = $("#mustr-edit").data('id');
    var transC = @(Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.JsonTransaction)));
    var trasnsJs = JSON.parse(transC);

    var placeholderElement = $('#modal-placeholder');

    var spinner = '<div class="d-flex justify-content-center"><div class="spinner-border text-primary" role="status"><span class="sr-only">Loading...</span></div></div>';

    // -------------- zobraz transakce -----------------------
    $(document).on("click", ".jsSetYearTrans", function () {

        var Y = $(this).data("id");
        var tbody = "";
        for (var key in trasnsJs) {
            // skip loop if the property is from prototype
            if (!trasnsJs.hasOwnProperty(key)) continue;

            var obj = trasnsJs[key];
            for (var prop in obj) {
                // skip loop if the property is from prototype
                if (!obj.hasOwnProperty(prop)) continue;

                if (key == Y) {
                    var o = obj[prop];
                    var castka = "";
                    if (o.Castka != null) {
                        castka = o.Castka + " kč";
                    }
                    var d = new Date(o.Datum);
                    var dt = d.getDate() + "." + (d.getMonth() + 1) + "." + d.getFullYear();
                    var t = d.getHours().pad(2, "0") + ":" + d.getMinutes().pad(2, "0");
                    var typ = "standardní";
                    if (o.Typ == "kc") {
                        typ = "časový";
                    }
                    var dokt = "";
                    if (o.Doklad > 0) {

                        dokt = '<button class="btn btn-sm btn-primary" onclick="$(\'#pokladniDoklad\').printpok(' + o.Id + ');"> Tisk </button>';
                    }
                    tbody += '<tr><td class="dt">' + dt + '</td><td class="tm">' + t + '</td><td> ' + o.ProvedlId + ' </td><td>' + typ + '</td><td>' + o.Status + '</td><td>' + o.Kredit + '</td><td class="kc">' + castka + '</td><td class="zb">' + o.Zbytek + '</td><td>' + dokt + '</td></tr>';
