                var drop = '<select class="custom-select" name="platbaID" onchange="0" data-id="' + id + '" style="width: 100%">';

                for (var index1 = 0; index1 < count; index1++) {
                    var row1 = data.items[index1];
                    var suma = row1.castka;
                    drop += '<option value="' + row1.id + '">' + suma.pad(4, "_") + ' - ' + row1.popis + '</option>'
                }
                drop += '</select>';

                t += drop + '</td></tr></table>';

                $('#drop-money').html(t);
                $('#jsAddMoneyForm').show();
