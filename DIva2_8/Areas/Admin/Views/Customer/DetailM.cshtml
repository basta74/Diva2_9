    // -------------- zobraz transakce prijem -----------------------
    $(document).on("click", ".jsSetYearTransPrijem", function () {

        var Y = $(this).data("id");
        var tbody = "";
        for (var key in trasnsJs) {
            // skip loop if the property is from prototype
            if (!trasnsJs.hasOwnProperty(key)) continue;

            var obj = trasnsJs[key];
            for (var prop in obj) {
                // skip loop if the property is from prototype
                if (!obj.hasOwnProperty(prop)) continue;

                if (key == Y) {
                    var o = obj[prop];
                    console.log(o);

                    if (o.Status == "+") {

                        var castka = "";
                        if (o.Castka != null) {
                            castka = o.Castka + " kč";
                        }
                        var d = new Date(o.Datum);
                        var dt = d.getDate() + "." + (d.getMonth() + 1) + "." + d.getFullYear();
                        var t = d.getHours().pad(2, "0") + ":" + d.getMinutes().pad(2, "0");
                        var typ = "standardní";
                        if (o.Typ == "kc") {
                            typ = "časový";
                        }
                        var dokt = "";
                        if (o.Doklad > 0) {
                            dokt = '<div class="badge badge-primary" onclick="$(\'#pokladniDoklad\').printpok(' + o.Id + ')"> Tisk </div>';
                            //dokt = '<button class="btn btn-sm btn-primary" onclick="$(\'#pokladniDoklad\').printpok(' + o.Id +');"> Tisk </button>';
                        }
                        tbody += '<tr><td class="dt">' + dt + '</td><td class="tm">' + t + '</td><td> ' + o.ProvedlId + ' </td><td>' + typ + '</td><td>' + o.Status + '</td><td>' + o.Kredit + '</td><td class="kc">' + castka + '</td><td class="zb">' + o.Zbytek + '</td><td style="cursor: pointer">' + dokt + '</td></tr>';
                    }
                }
            }
        }

        $("#jsTableTransPrijem").show();
        $("#jsTableTransPrijemBody").html(tbody);

    });

