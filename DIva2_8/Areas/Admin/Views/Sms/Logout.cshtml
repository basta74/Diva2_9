@using Diva2Web.Models.Admin
@using Diva2.Core.Main.Trans
@using Diva2.Core;

@model AdminPageModel

@{

    IPagedList<UserLekceLogOut> list = ViewBag.logs as IPagedList<UserLekceLogOut>;

}

<div id="modal-placeholder"></div>

<partial name="Main/Pagination" />

<table class="table table-hover">
    <tr>
        <th>Provedl</th>
        <th>Zákazník</th>
        <th>Lekce</th>
        <th>Počet zák.</th>
        <th>Pořadí</th>
        <th>Počet náhr.</th>

        <th>Existuje náhr.</th>
        <th>Je zák. v lekci</th>
        <th>Brána akt?</th>
        <th>Komu posláno</th>
        <th>Odesláno</th>
        <th>Datum</th>
    </tr>

    @foreach (var l in list.Data)
    {
        <tr class="jsFormModal">
            <td class="jmeno" style="cursor: pointer" data-id="@l.ProvedlId"> id: @l.ProvedlId</td>
            <td class="jmeno" style="cursor: pointer" data-id="@l.UserId">id: @l.UserId</td>
            <td>@l.LekceId</td>
            <td>@l.PocetMist</td>
            <td>@l.Poradi</td>
            <td>@l.PocetZakazniku</td>
            <td>@Html.Raw(l.ExistujeNahradnik ? "<span style='color: green'><b>ano</b></span>" : "<span style='color: red'>ne</span>")</td>
            @if (l.ExistujeNahradnik)
            {
                <td>@Html.Raw(l.JePlatny ? "<span style='color: green'><b>ano</b></span>" : "<span style='color: red'>ne</span>")</td>
                @if (l.JePlatny)
                {
                    <td>@Html.Raw(l.SmsActive ? "<span style='color: green'><b>ano</b></span>" : "<span style='color: red'>ne</span>")</td>
                    if (l.SmsActive)
                    {
                        <td class="jmeno" style="cursor: pointer" data-id="@l.SmsUserId"> id: @l.SmsUserId</td>
                        <td>@Html.Raw(l.SmsStatus == 0 ? "<span style='color: green'><b>ano</b></span>" : $"<span style='color: red'>chyba {l.SmsStatus}</span>")</td>
                    }
                    else
                    {
                        <td colspan="2"></td>
                    }
                }
                else
                {
                    <td colspan="3"></td>
                }
            }
            else
            {
                <td colspan="4"></td>
            }
            <td>@l.TsCz</td>

        </tr>
    }
</table>

<partial name="Main/Pagination" />

@section Scripts{
    <script>
        $(document).ready(function () {

            var placeholderElement = $('#modal-placeholder');

            $(document).on('click', 'tr.jsFormModal td.jmeno', function (event) {
                var zakId = $(this).data('id');
                showZak(zakId);
            });

            function showZak(zakId) {
                $.ajax({
                    method: "GET",
                    url: "/Admin/Customer/DetailM",
                    data: { id: zakId }
                }).done(function (data) {
                    placeholderElement.html(data);
                    placeholderElement.find('.modal').modal('show');
                });
            }
        });
    </script>
}